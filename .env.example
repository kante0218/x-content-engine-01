# Account: @kante0123 (髙橋敢輝 / clear AI株式会社 代表)
# X Developer App: https://developer.x.com → Projects & Apps → 該当App → Keys and tokens
# ※ @oxp_emiri / @wakana_emeta とは別アカウントなので、別の X Developer App が必要

# --- OAuth 1.0a User Context (投稿) ---
X_CONSUMER_KEY=
X_CONSUMER_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_TOKEN_SECRET=

# --- 運用対象アカウント ---
X_HANDLE=kante0123
X_USER_ID=

# --- 文字数上限 ---
# 通常(無料)アカウント: 280。X Premium(長文ポスト)契約なら 900 などに上げると長文化する。
X_MAX_CHARS=280

# --- Claude API (生成・推敲用) ---
ANTHROPIC_API_KEY=

# 既定: false=ドラフト推敲のみで実投稿しない、true=推敲後にX本番投稿
X_LIVE_POST=false

# --- バズ運用: コメ欄(自己リプ)に『具体の続き』を置くスレッド投稿の確率 ---
# 0〜1。0.4=約4割の投稿で、本文(フック+結論)→コメ欄に手順/設定値の続きを自己リプ。
# 0 にすると常に単発投稿。引用RTのドラフトとは併用しない。
X_REPLY_THREAD_RATE=0.4
